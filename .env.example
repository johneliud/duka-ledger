# Supabase Configuration
SUPABASE_PROJECT_URL=https://your-project.supabase.co
SUPABASE_ANON_PUBLIC=your-anon-key-here
SUPABASE_SERVICE_ROLE_SECRET=your-service-role-key-here
SUPABASE_DB_URI=postgresql://postgres.your-project:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Database Connection (individual params - optional if using SUPABASE_DB_URI)
DB_HOST=aws-0-region.pooler.supabase.com
DB_NAME=postgres
DB_USER=postgres.your-project
DB_PASSWORD=your-password

# Backend Configuration
API_URL=http://localhost:3001
JWT_SECRET=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.com

# PowerSync (optional - for production)
POWERSYNC_URL=
